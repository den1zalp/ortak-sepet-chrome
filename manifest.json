{
  "manifest_version": 3,
  "name": "Ortak Sepet",
  "version": "0.1.8",
  "description": "Türkiye odaklı ortak alışveriş sepeti.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.trendyol.com/*",
    "*://*.hepsiburada.com/*",
    "*://*.n11.com/*",
    "*://*.amazon.com.tr/*",
    "*://*.teknosa.com/*",
    "*://*.vatanbilgisayar.com/*",
    "*://*.mediamarkt.com.tr/*",
    "*://*.pazarama.com/*",
    "*://*.ciceksepeti.com/*",
    "*://*.idefix.com/*",
    "*://*.dr.com.tr/*",
    "*://*.itopya.com/*",
    "*://*.incehesap.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Ortak Sepet",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.trendyol.com/*",
        "*://*.hepsiburada.com/*",
        "*://*.n11.com/*",
        "*://*.amazon.com.tr/*",
        "*://*.teknosa.com/*",
        "*://*.vatanbilgisayar.com/*",
        "*://*.mediamarkt.com.tr/*",
        "*://*.pazarama.com/*",
        "*://*.ciceksepeti.com/*",
        "*://*.idefix.com/*",
        "*://*.dr.com.tr/*",
        "*://*.itopya.com/*",
        "*://*.incehesap.com/*"
      ],
      "js": [
        "browser-polyfill.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
